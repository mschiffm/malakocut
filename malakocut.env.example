# Malakocut Configuration

# --- Network Settings ---
# The interface to sniff traffic from (SPAN/Mirror port)
MALAKOCUT_INTERFACE="enp3s0"

# --- Exporter Settings ---
# Options: "secops" or "none"
MALAKOCUT_EXPORTER="none"

# --- Google SecOps (Required if MALAKOCUT_EXPORTER="secops") ---
CHRONICLE_CUSTOMER_ID="your-uuid-here"
# Path to your Google Cloud Service Account JSON key
GOOGLE_APPLICATION_CREDENTIALS="/etc/malakocut/secops_key.json"
# Chronicle Ingestion API URL (Standard v2 endpoint)
CHRONICLE_INGESTION_URL="https://malachiteingestion-pa.googleapis.com/v2/unstructuredlogentries:batchCreate"
# Optional Log Type
CHRONICLE_LOG_TYPE="MALAKOCUT_NETWORK_CUSTOM"

# --- Email Reporting (Optional) ---
# Sign up at sendgrid.com for an API key
SENDGRID_API_KEY=""
MAIL_FROM="malakocut@example.com"
MAIL_TO="you@example.com"

# --- Advanced Tuning ---
# MALAKOCUT_MAX_FLOWS=100000
# MALAKOCUT_FILTER="not (broadcast or multicast)"
